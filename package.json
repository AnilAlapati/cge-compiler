{
  "name": "cge-compiler",
  "version": "1.0.0",
  "description": "[![TypeScript](https://img.shields.io/badge/Language-TypeScript-blue.svg)](https://www.typescriptlang.org/) [![License: MIT](https://img.shields.io/badge/License-MIT-green.svg)](https://opensource.org/licenses/MIT) [![Build Status](https://img.shields.io/badge/Build-Passing-brightgreen.svg)]()",
  "main": "index.js",
  "scripts": {
    "test": "ts-node src/test_runner.ts",
    "compile": "ts-node src/cge_compiler_runner.ts",
    "cge-copy": "ts-node src/cli/clipboard_tool.ts",
    "build:cli": "npx esbuild src/cli/index.ts --bundle --platform=node --outfile=dist/cli.js",
    "build:browser": "npx esbuild packages/leancontext-core/src/browser.ts --bundle --platform=browser --outfile=dist/leancontext_engine.js",
    "build": "node build.js && npm run build:cli && npm run build:browser",
    "benchmark": "npx tsx scripts/benchmark.ts",
    "eval": "npx tsx scripts/eval_runner.ts",
    "blind-score": "npx tsx scripts/blind_score.ts",
    "workflow-poc": "npx tsx scripts/workflow_poc.ts"
  },
  "bin": {
    "cge-cli": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnilAlapati/cge-compiler.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "workspaces": [
    "packages/*"
  ],
  "bugs": {
    "url": "https://github.com/AnilAlapati/cge-compiler/issues"
  },
  "homepage": "https://github.com/AnilAlapati/cge-compiler#readme",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "terser": "^5.48.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@google/generative-ai": "^0.24.1",
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^17.4.2",
    "jszip": "^3.10.1",
    "openai": "^6.39.1",
    "puppeteer": "^25.1.0"
  }
}
