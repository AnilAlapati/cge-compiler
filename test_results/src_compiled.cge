      case ".ts":
      case ".tsx":
      case ".js":
      case
  CGECompiler.getParserForLanguage(language:S)->CGEParser:
    switch (language.toLowerCase()) {
      case "typescript":
      case "ts":
    

EXPORTS: CGECompiler


