PRIVATE:
  callLLM(prompt:S, provider:S, model:S)->Promise<S>:
    IF provider==="openai": response = await openai.chat.completions.create({model:model,messages:[{role:"user",content:prompt}],temperature:0.1}), RETURN response.choices[0].message.content||""
    IF provider==="gemini": geminiModel = genAI.getGenerativeModel({model:model}), result = await geminiModel.generateContent({contents:[{role:"user",parts:[{text:prompt}]}],generationConfig:{temperature:0.1}}), RETURN result.response.text()
    THROW new Error(`Unsupported provider: ${provider}`)
  normalizeCGELine(line:S)->S:
    cleanLine = line.trim()
    IF !cleanLine.startsWith("SCAN")&&!cleanLine.startsWith("GUARD")&&!cleanLine.startsWith("RETURN")&&!cleanLine.startsWith("TRY")&&!cleanLine.startsWith("THROW"): cleanLine=cleanLine.replace(/->.*/g,"")
    RETURN cleanLine.replace(/^(?:IMPORTS|TYPES|STATE|OPS|PRIVATE|EXPORTS):?/gi,"").replace(/\b(?:EXPORT|CONST)\b/gi,"").replace(/:(?:S|N|B|D|any|void)\b/g,"").replace(/->/g,"").replace(/:/g,"").replace(/\s+/g," ").trim()
  normalizeCGE(cge:S)->S:
    RETURN cge.split("
").map((line)=>line.trim()).filter((line)=>line.length>0).join("
")
  diffCGE(original:S, reconstructed:S)->{ missing: string[]; extra: string[] }:
    filterNoise = (line)=>clean = normalizeCGELine(line)
RETURN clean.length>0&&!line.startsWith("CGE/1.0")&&!line.startsWith("EXPORTS:")
    origLines = normalizeCGE(original).split("
").filter(filterNoise)
    reconLines = normalizeCGE(reconstructed).split("
").filter(filterNoise)
    normRecon = reconLines.map((l)=>normalizeCGELine(l))
    missing = origLines.filter((l)=>!normRecon.includes(normalizeCGELine(l)))
    extra = reconLines.filter((l)=>!origLines.map((o)=>normalizeCGELine(o)).includes(normalizeCGELine(l)))
    RETURN {missing,extra}
  runFidelityLoop(originalCode:S, cgeCode:S, fileName:S, compiler:CGECompiler)->Promise<BenchmarkResult>:
    SCAN MODEL_TIERS FOR const tier -> classNames = new Set(), classMatches = cgeCode.matchAll(/([A-Z][a-zA-Z0-9_]+)\.[a-zA-Z0-9_]+/g), SCAN classMatches FOR const match -> classNames.add(match[1]), classInstructions = "", IF classNames.size>0: classInstructions=`
3. The following entities MUST be reconstructed strictly as CLASSES using the 'class' keyword (e.g. 'class ClassName { ... }') and NOT as constant objects or plain dictionaries:
`+Array.from(classNames).map((name)=>`   - ${name}`).join("
"), currentPrompt = `Act as an expert compiler. Below is a code block translated into Cognitive Graph Encoding (CGE) loss-less shorthand notation.
Decompress this CGE shorthand back into fully working, standard source code. 

CRITICAL REQUIREMENTS:
1. Do NOT wrap in markdown code fences or explain anything, just return the raw code.
2. STRICTLY preserve the original programming constructs. 
   - If the CGE block defines a class (e.g. under OPS: or STATE: matching a class name), you MUST reconstruct it as a class with its member variables and methods.
   - If the CGE block defines an interface or type, reconstruct it exactly.
   - Match all exported variables, classes, hooks, and function signatures.
   - In Python, if a class has type mappings (e.g. UserProfile{id:S, email:S, created_at:D}), you MUST declare these fields as class-level type annotations directly in the class body (e.g. id: str).
   - Reconstruct all loop targets and member accesses exactly as written in CGE (e.g. if CGE says SCAN user.items, write 'for item in user.items:').${classInstructions}

CGE Code:
${cgeCode}`, success = false, MAX_LOOPS = 3, loop = 1, SCAN  FOR i -> TRY: reconstructedCode = await callLLM(currentPrompt,tier.provider,tier.model), cleanCode = reconstructedCode.replace(/```[a-zA-Z]*\n/g,"").replace(/```/g,"").trim(), ext = path.extname(fileName).toLowerCase(), lang = "typescript", IF ext===".py": lang="python", IF ext===".rs": lang="rust", candidateCGE = compiler.compileCode(cleanCode,lang,fileName), DESTRUCTURE { missing, extra } = diffCGE(cgeCode,candidateCGE), IF missing.length===0: success=true, break; ELSE missing.forEach((m)=>console.log(`      - ${m}`)), patches = [], SCAN missing FOR const m -> patches.push(`[PATCH: Missing structure/function logic matching '${m}'. Reimplement this correctly]`), currentPrompt+=`

[SYSTEM ERROR - SEMANTIC AST MISMATCH DETECTED IN YOUR LAST RESPONSE]
Please regenerate the code and apply the following logical constraints:
${patches.join("
")}` CATCH: break;, IF success: RETURN {fileName,originalSize:originalCode.length,compressedSize:cgeCode.length,ratio:(originalCode.length/cgeCode.length).toFixed(2)+"x",successfulModel:tier.model,loopsNeeded:loop,success:true} ELSE
    RETURN {fileName,originalSize:originalCode.length,compressedSize:cgeCode.length,ratio:(originalCode.length/cgeCode.length).toFixed(2)+"x",successfulModel:"None (Failed)",loopsNeeded:0,success:false}
  main()->void:
    testFilesDir = path.resolve("./test_files")
    IF !fs.existsSync(testFilesDir): process.exit(1)
    files = fs.readdirSync(testFilesDir).filter((f)=>ext = path.extname(f).toLowerCase()
RETURN [".ts",".py",".rs"].includes(ext))
    IF files.length===0: RETURN void
    compiler = new CGECompiler()
    results = []
