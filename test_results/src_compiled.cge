"
    SCAN results FOR const r -> csvContent+=`"${r.fileName}",${r.originalSize},${r.compressedSize},"${r.ratio}","${r.successfulModel}",${r.loopsNeeded},${r.success}
`
    fs.writeFileSync(csvPath,csvContent,"utf-8")


// --- File: src/cge_compiler.ts ---
CGE/1.0 cge_compiler (TypeScript)

IMPORTS:
  * as fs from fs
  * as path from path
  CGEParser from ./cge_parser
  TypeScriptParser from ./typescript_parser
  PythonParser from ./python_parser
  RustParser from ./rust_parser

STATE:
  EXPORT CGECompiler.filePaths:S[]

OPS:
  EXPORT CGECompiler.compileCode(code:S, language:S, fileName:S)->S:
    parser = this.getParserForLanguage(language)
    parsed = parser.parse(code,fileName)
    compName = fileName?path.basename(fileName,path.extname(fileName)):"Component"
    isHook = compName.startsWith("use")
    langLabel = language==="typescript"?(isHook?"(ReactHook)":"(TypeScript)"):`(${language.charAt(0).toUpperCase()+language.slice(1)})`
    header = `CGE/1.0 ${compName}${langLabel}
`
    output = header+"
"
    IF parsed.imports.length>0: output+=`IMPORTS:
  ${parsed.imports.join("
  ")}

`
    IF parsed.types.length>0: output+=`TYPES:
  ${parsed.types.join("
  ")}

`
    IF parsed.state.length>0: output+=`STATE:
  ${parsed.state.join("
  ")}

`
    IF parsed.ops.length>0: output+=`OPS:
  ${parsed.ops.join("

  ")}

`
    IF parsed.privateOps.length>0: output+=`PRIVATE:
  ${parsed.privateOps.join("
  ")}

`
    IF parsed.exports.length>0: output+=`EXPORTS: ${parsed.exports.join(", ")}
`
    RETURN output.trim()+"
"

  EXPORT CGECompiler.compile(filePath:S)->S:
    resolvedPath = path.resolve(filePath)
    GUARD !fs.existsSync(resolvedPath) THROW new Error(`Source file not found: ${filePath}`)
    code = fs.readFileSync(resolvedPath,"utf-8")
    ext = path.extname(resolvedPath).toLowerCase()
    language = this.getLanguageFromExtension(ext)
    RETURN this.compileCode(code,language,path.basename(resolvedPath))

PRIVATE:
